{
  "name": "gitouch",
  "version": "1.0.0",
  "description": "你的复制记录和速写草稿本，合二为一",
  "author": "Gitouch Team",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "package": "electron-builder --win --dir",
    "package:full": "electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.11",
    "marked": "^15.0.12",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sql.js": "^1.11.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "css-loader": "^6.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.2",
    "style-loader": "^3.0.0",
    "to-ico": "^1.1.5",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.gitouch.app",
    "productName": "Gitouch",
    "directories": {
      "output": "dist-final"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "asar": false,
    "win": {
      "target": [
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  }
}
